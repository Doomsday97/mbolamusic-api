# ====== Servidor ======
PORT=4000
NODE_ENV=development

# ====== Base de datos (PostgreSQL) ======
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mbolamusic?schema=public"

# ====== Seguridad ======
JWT_SECRET="cambia_esto_por_una_cadena_larga_y_secreta"
JWT_EXPIRES_IN="30d"

# ====== Pagos ======
# Proveedor activo: "mock" (pruebas, sin claves) o "flutterwave"
PAYMENT_PROVIDER="mock"

# Flutterwave (rellenar solo si usas flutterwave)
FLW_PUBLIC_KEY=""
FLW_SECRET_KEY=""
FLW_ENCRYPTION_KEY=""
FLW_WEBHOOK_HASH=""
FLW_REDIRECT_URL=""                 # URL de retorno tras pago con tarjeta (3DS)

# Datos para pago por transferencia bancaria (se muestran al usuario)
BANK_NAME="Nombre del Banco"
BANK_ACCOUNT_NAME="MbôláMusic SARL"
BANK_ACCOUNT_NUMBER="000000000000"

# ====== Almacenamiento de audio ======
# "local" (carpeta uploads/, solo desarrollo) o "s3" (producción)
STORAGE_PROVIDER="local"
UPLOAD_DIR="uploads"

# Variables requeridas solo si STORAGE_PROVIDER="s3"
# Compatible con: AWS S3, Backblaze B2, Wasabi, Cloudflare R2, MinIO
# Instalar: npm install @aws-sdk/client-s3 @aws-sdk/lib-storage

S3_BUCKET=""                        # nombre del bucket
S3_REGION="auto"                    # región, p.ej. "us-east-005" en Backblaze
S3_ACCESS_KEY=""                    # Access Key ID
S3_SECRET_KEY=""                    # Secret Access Key
S3_ENDPOINT=""                      # solo si NO es AWS S3, p.ej. "https://s3.us-east-005.backblazeb2.com"
S3_FORCE_PATH_STYLE="false"         # "true" para Backblaze B2 y MinIO
S3_ACL="public-read"                # "public-read" o "private" (con CDN)

# URL base del CDN (opcional pero recomendado para mejorar velocidad en África)
# Si está vacía se construye automáticamente desde S3_ENDPOINT + S3_BUCKET
CDN_BASE_URL=""                     # p.ej. "https://cdn.tudominio.com"
